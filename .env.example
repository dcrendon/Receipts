# Common
# PROVIDER options: gitlab, jira, all
PROVIDER=gitlab

# Output file used when provider is gitlab or jira.
# For provider=all, the tool writes gitlab_issues.json and jira_issues.json.
OUT_FILE=gitlab_issues.json

# TIME_RANGE options: week, month, year, custom
TIME_RANGE=week

# FETCH_MODE options: my_issues, all_contributions
FETCH_MODE=all_contributions

# Required when TIME_RANGE=custom. Format: MM-DD-YYYY
START_DATE=01-01-2026
END_DATE=01-31-2026

# GitLab (required when provider=gitlab or all)
GITLAB_PAT=your_gitlab_pat
GITLAB_URL=https://gitlab.com

# Jira (required when provider=jira or all)
JIRA_PAT=your_jira_pat
JIRA_URL=https://jira.example.com
JIRA_USERNAME=your_jira_username

